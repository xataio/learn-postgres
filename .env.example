# Postgres connection for app metadata (better-auth tables, progress, branch registry).
# Use the Xata "main" branch connection string.
DATABASE_URL="postgresql://..."

# better-auth
# Generate with: openssl rand -base64 32
# BETTER_AUTH_SECRET must be identical across production AND preview so the
# oAuthProxy can encrypt/decrypt the OAuth payload it bounces between them.
BETTER_AUTH_SECRET="<generate secret>"
# Points at the production origin. On Vercel set this to your production URL in
# EVERY environment (Production + Preview) — the oAuthProxy uses it as the
# OAuth callback target so preview deployments don't each need their own
# GitHub app. Locally it's just your dev origin.
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# GitHub OAuth
# Create at: https://github.com/settings/developers
# Register ONLY the production callback URL — preview deployments proxy
# through it via oAuthProxy:
#   Authorization callback URL: https://<production-domain>/api/auth/callback/github
# Locally use: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Xata branch management — required to spin up a Postgres sandbox per lesson.
# API key:    https://app.xata.io/  →  Account settings  →  API keys
# Org ID:     visible in the URL of any Xata page under app.xata.io/orgs/<ORG>
# Project ID: project page URL: app.xata.io/orgs/<ORG>/projects/<PROJECT>
XATA_API_KEY=""
XATA_ORG_ID=""
XATA_PROJECT_ID=""
# Optional — the branch user sandboxes fork from. Defaults to the branch
# named "main". Set this to a branch name or ID to override.
# XATA_PARENT_BRANCH="main"

# Cron job auth (used by /api/cron/cleanup-branches).
# Vercel Cron sends Authorization: Bearer ${CRON_SECRET}.
CRON_SECRET=""

# Idle threshold (days) before cleanup drops a branch. Default: 7.
# BRANCH_IDLE_DAYS=7

# How long the shell waits for a sleeping Xata branch to come back online
# before reporting a connection error. Default: 30000 (30s).
# BRANCH_CONNECT_TIMEOUT_MS=30000

# Max concurrent sandbox branches per user. When a learner opens an N+1th
# lesson, the least-recently-used branch is evicted to make room.
# MAX_BRANCHES_PER_USER=5

# Shell rate limit: max requests to /api/lessons/[slug]/query per user
# within QUERY_RATE_WINDOW_MS (default 30 queries / 10 seconds).
# QUERY_RATE_LIMIT=30
# QUERY_RATE_WINDOW_MS=10000

# Branch creation rate limit: max new Xata branches (lesson first-visit OR
# reset) per user within BRANCH_CREATE_WINDOW_MS. Default 5 / 60 seconds.
# BRANCH_CREATE_LIMIT=5
# BRANCH_CREATE_WINDOW_MS=60000
