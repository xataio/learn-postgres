# Postgres connection for app metadata (better-auth tables, progress, branch registry).
# Use the Xata "main" branch connection string.
DATABASE_URL="postgresql://..."

# better-auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="<generate secret>"
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# GitHub OAuth
# Create at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Xata (used from Phase 2 onward, for per-(user, lesson) branches)
# XATA_API_KEY=""
# XATA_WORKSPACE=""
# XATA_DATABASE=""
